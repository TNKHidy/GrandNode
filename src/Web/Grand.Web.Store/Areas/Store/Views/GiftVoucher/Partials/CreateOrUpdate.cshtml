@model GiftVoucherModel

<div asp-validation-summary="All"></div>
<input asp-for="Id" type="hidden"/>
<input asp-for="StoreId" type="hidden"/>
<admin-tabstrip name="giftvoucher-edit">
    <items>
        <tabstrip-item text="@Loc["Admin.GiftVouchers.Info"]" tab-index="0">
            <content>
                <div>
                    <partial name="Partials/CreateOrUpdate.TabInfo" model="Model"/>
                </div>
            </content>
        </tabstrip-item>
        @if (!string.IsNullOrEmpty(Model.Id))
        {
            <tabstrip-item text="@Loc["Admin.GiftVouchers.History"]" tab-index="1">
                <content>
                    <div>
                        <partial name="Partials/CreateOrUpdate.TabHistory" model="Model"/>
                    </div>
                </content>
            </tabstrip-item>
        }
    </items>
</admin-tabstrip>
