@model PickupPointModel
@{
    ViewBag.Title = Loc["Admin.Configuration.Shipping.PickupPoints.EditDetails"];
    Layout = Constants.LayoutStore;
}
<form asp-area="@Constants.AreaStore" asp-controller="Shipping" asp-action="EditPickupPoint" method="post">
    <div class="row">
        <div class="col-md-12">
            <div class="x_panel light form-fit">
                <div class="x_title">
                    <div class="caption">
                        <i class="fa fa-list-alt"></i>
                        @Loc["Admin.Configuration.Shipping.PickupPoints.EditDetails"] - @Model.Name
                        <small>
                            <i class="fa fa-arrow-circle-left"></i>
                            <a href="@Url.Action("PickupPoints", "Shipping", new { area = Constants.AreaStore })">@Loc["Admin.Configuration.Shipping.PickupPoints.BackToList"]</a>
                        </small>
                    </div>
                    <div class="actions">
                        <div class="btn-group btn-group-devided util-btn-margin-bottom-5">
                            <button class="btn btn-success" type="submit" name="save">
                                <i class="fa fa-check"></i> @Loc["Admin.Common.Save"]
                            </button>
                            <button class="btn btn-success" type="submit" name="save-continue">
                                <i class="fa fa-check-circle"></i> @Loc["Admin.Common.SaveContinue"]
                            </button>
                            <span id="pickuppoint-delete" class="btn red">
                                <i class="fa fa-trash-o"></i> <span class="d-none d-sm-inline">@Loc["Admin.Common.Delete"]</span>
                            </span>
                        </div>
                    </div>
                </div>
                <div class="x_content form">
                    <partial name="Partials/CreateOrUpdatePickupPoint" model="Model"/>
                </div>
            </div>
        </div>
    </div>
</form>
<admin-delete-confirmation button-id="pickuppoint-delete" action-name="DeletePickupPoint"/>
