@model ContactAttributeStoreModel
@{
    var isReadOnly = Model.IsReadOnly;

    if (!string.IsNullOrEmpty(Model.Id))
    {
        <div class="panel panel-default">
            <div class="panel-body">
                <div id="contactattributevalues-grid"></div>
            </div>
            @if (!isReadOnly)
            {
                <div class="panel-footer">
                    <a id="btnAddNewValue" href="@(Url.Action("ValueCreatePopup", "ContactAttribute", new { contactAttributeId = Model.Id, area = Constants.AreaStore }))" class="k-button"><i class="fa fa-plus"></i>&nbsp;@Loc["Admin.Catalog.Attributes.ContactAttributes.Values.AddNew"]</a>
                    <input type="submit" id="btnRefresh" style="display: none"/>
                </div>
            }
            else
            {
                <input type="submit" id="btnRefresh" style="display: none"/>
            }
        </div>

        if (!isReadOnly)
        {
            <script>
                $(document).ready(function () {
                    $('#btnAddNewValue').magnificPopup({
                        type: 'ajax',
                        settings: { cache: false, async: false },
                        midClick: true,
                        callbacks: {
                            parseAjax: function (mfpResponse) {
                                mfpResponse.data = $('<div></div>').html(mfpResponse.data);
                            },
                            ajaxContentAdded: function () {
                                $('.mfp-wrap').removeAttr('tabindex');
                            }
                        }
                    });

                    $("#contactattributevalues-grid").kendoGrid({
                        dataBound: function () {
                            $('.editvalue').magnificPopup({
                                type: 'ajax',
                                settings: { cache: false, async: false },
                                midClick: true,
                                callbacks: {
                                    parseAjax: function (mfpResponse) {
                                        mfpResponse.data = $('<div></div>').html(mfpResponse.data);
                                    },
                                    ajaxContentAdded: function () {
                                        $('.mfp-wrap').removeAttr('tabindex');
                                    }
                                }
                            });
                        },
                        dataSource: {
                            transport: {
                                read: {
                                    url: "@Html.Raw(Url.Action("ValueList", "ContactAttribute", new { contactAttributeId = Model.Id, area = Constants.AreaStore }))",
                                    type: "POST",
                                    dataType: "json",
                                    data: addAntiForgeryToken
                                },
                                destroy: {
                                    url: "@Html.Raw(Url.Action("ValueDelete", "ContactAttribute", new { area = Constants.AreaStore }))",
                                    type: "POST",
                                    dataType: "json",
                                    data: addAntiForgeryToken
                                }
                            },
                            schema: {
                                data: "Data",
                                total: "Total",
                                errors: "Errors",
                                model: { id: "Id" }
                            },
                            error: function(e) {
                                display_kendoui_grid_error(e);
                                this.cancelChanges();
                            },
                            serverPaging: true,
                            serverFiltering: true,
                            serverSorting: true
                        },
                        pageable: { refresh: true, numeric: false, previousNext: false, info: false },
                        editable: { confirmation: true, mode: "inline" },
                        scrollable: false,
                        columns: [{
                            field: "Name",
                            title: "@Loc["Admin.Catalog.Attributes.ContactAttributes.Values.Fields.Name"]",
                            template: "<a class='k-link editvalue' href=\"@Url.Action("ValueEditPopup", "ContactAttribute", new { area = Constants.AreaStore })/#=Id#?contactAttributeId=@Model.Id\">#=kendo.htmlEncode(Name)#</a>"
                        }, {
                            field: "IsPreSelected",
                            title: "@Loc["Admin.Catalog.Attributes.ContactAttributes.Values.Fields.IsPreSelected"]",
                            width: 100,
                            minScreenWidth: 500,
                            headerAttributes: { style: "text-align:center" },
                            attributes: { style: "text-align:center" },
                            template: '# if(IsPreSelected) {# <i class="fa fa-check" aria-hidden="true" style="color:green"></i> #} else {# <i class="fa fa-times" aria-hidden="true" style="color:red"></i> #} #'
                        }, {
                            field: "DisplayOrder",
                            title: "@Loc["Admin.Catalog.Attributes.ContactAttributes.Values.Fields.DisplayOrder"]",
                            headerAttributes: { style: "text-align:center" },
                            attributes: { style: "text-align:center" },
                            width: 100
                        }, {
                            command: { name: "destroy", text: "@Loc["Admin.Common.Delete"]" },
                            title: "@Loc["Admin.Common.Delete"]",
                            width: 100
                        }]
                    });

                    $('#btnRefresh').click(function () {
                        var grid = $("#contactattributevalues-grid").data('kendoGrid');
                        grid.dataSource.read();
                        return false;
                    });
                });
            </script>
        }
        else
        {
            <script>
                $(document).ready(function () {
                    $("#contactattributevalues-grid").kendoGrid({
                        dataSource: {
                            transport: {
                                read: {
                                    url: "@Html.Raw(Url.Action("ValueList", "ContactAttribute", new { contactAttributeId = Model.Id, area = Constants.AreaStore }))",
                                    type: "POST",
                                    dataType: "json",
                                    data: addAntiForgeryToken
                                }
                            },
                            schema: {
                                data: "Data",
                                total: "Total",
                                errors: "Errors",
                                model: { id: "Id" }
                            },
                            error: function(e) {
                                display_kendoui_grid_error(e);
                                this.cancelChanges();
                            },
                            serverPaging: true,
                            serverFiltering: true,
                            serverSorting: true
                        },
                        pageable: { refresh: true, numeric: false, previousNext: false, info: false },
                        scrollable: false,
                        columns: [{
                            field: "Name",
                            title: "@Loc["Admin.Catalog.Attributes.ContactAttributes.Values.Fields.Name"]"
                        }, {
                            field: "IsPreSelected",
                            title: "@Loc["Admin.Catalog.Attributes.ContactAttributes.Values.Fields.IsPreSelected"]",
                            width: 100,
                            minScreenWidth: 500,
                            headerAttributes: { style: "text-align:center" },
                            attributes: { style: "text-align:center" },
                            template: '# if(IsPreSelected) {# <i class="fa fa-check" aria-hidden="true" style="color:green"></i> #} else {# <i class="fa fa-times" aria-hidden="true" style="color:red"></i> #} #'
                        }, {
                            field: "DisplayOrder",
                            title: "@Loc["Admin.Catalog.Attributes.ContactAttributes.Values.Fields.DisplayOrder"]",
                            headerAttributes: { style: "text-align:center" },
                            attributes: { style: "text-align:center" },
                            width: 100
                        }]
                    });
                });
            </script>
        }
    }
    else
    {
        <div class="note note-info">
            @Loc["Admin.Catalog.Attributes.ContactAttributes.Values.SaveBeforeEdit"]
        </div>
    }
}
